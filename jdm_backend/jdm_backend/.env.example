# Core Settings
DJANGO_SECRET_KEY=django-insecure-4=3%z6!v&9fx@2lq^7p*u0s$k8n!m5b@r1w+y=e6t?g9h1
DJANGO_DEBUG=False

# Allowed Hosts (Comma-separated list of domains or IPs)
DJANGO_ALLOWED_HOSTS=api.jdmgroups.com,jdm.datamoshtechnologies.com,localhost,127.0.0.1

# CORS & CSRF Settings (Comma-separated list of origins)
