DJANGO_CSRF_TRUSTED_ORIGINS=https://jdm.datamoshtechnologies.com,https://api.jdmgroups.com

# Database Connection (Defaults to local db.sqlite3 if omitted)
DJANGO_DB_ENGINE=postgresql
